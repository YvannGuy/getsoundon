    "update-communes": "curl -s 'https://geo.api.gouv.fr/communes?codeRegion=11&fields=nom&format=json' | node -e \"const c=[];process.stdin.on('data',d=>c.push(d));process.stdin.on('end',()=>{const n=JSON.parse(Buffer.concat(c).toString()).map(x=>x.nom).sort((a,b)=>a.localeCompare(b,'fr'));require('fs').writeFileSync('lib/data/communes-idf.json',JSON.stringify(n));console.log(n.length+' communes')});\"",
