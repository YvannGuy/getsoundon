# Copier vers .env.local et renseigner les valeurs.

# Supabase : Dashboard → ton projet → Settings (roue dentée) → API
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - anon public → NEXT_PUBLIC_SUPABASE_ANON_KEY
# - service_role (secret, ne jamais committer ni exposer au navigateur) → SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# true | 1 | yes = catalogue en données fictives (11 annonces), sans lire Supabase sur GET listings
MOCK_GS_LISTINGS=

# Pré-lancement : live (défaut) | coming_soon — redirige le public vers /coming-soon (voir proxy.ts)
SITE_MODE=live

# Secret pour GET /api/prelaunch/enable?token=... (long, aléatoire, jamais exposé au client)
PRELAUNCH_BYPASS_TOKEN=
